# =============================================================================
# AI PR Reviewer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before starting the app.
#   cp .env.example .env
# =============================================================================

# --- Database -----------------------------------------------------------------
# PostgreSQL connection string (local or hosted, e.g., Neon, Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_pr_reviewer

# --- App URLs -----------------------------------------------------------------
# Public-facing URL of your app (used for Polar return URL, auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL for webhook endpoints (use ngrok URL for local testing)
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# --- GitHub OAuth -------------------------------------------------------------
# Create a GitHub OAuth App: https://github.com/settings/developers
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- GitHub Webhook Secret ----------------------------------------------------
# Generate a random secret used to verify incoming webhook payloads:
#   openssl rand -hex 32
# This MUST be set in production to prevent forged webhook events
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# --- AI Provider (OpenAI-compatible) ------------------------------------------
# Any OpenAI-compatible API provider.
# Examples:
#   OpenAI:       https://api.openai.com/v1
#   Google AI:    https://generativelanguage.googleapis.com/v1beta/openai
#   OpenRouter:   https://openrouter.ai/api/v1
#   Local LLM:    http://localhost:8080/v1
OPENAI_COMPATIBLE_API_KEY=your_api_key
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_MODEL=gpt-4o

# --- Pinecone Vector Database -------------------------------------------------
# Create an index at https://app.pinecone.io
# Index name is hardcoded as "ai-pr-reviewer-index" in lib/pinecone.ts
PINECONE_DB_API_KEY=your_pinecone_api_key

# --- Better Auth --------------------------------------------------------------
# Generate a random secret:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=your_random_secret
BETTER_AUTH_URL=http://localhost:3000

# --- Polar.sh (Subscription & Billing) ----------------------------------------
# Get these from your Polar.sh dashboard
POLAR_ACCESS_TOKEN=your_polar_access_token
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret
POLAR_SUCCESS_URL=http://localhost:3000/dashboard/subscriptions
# Server mode: "sandbox" for testing, "production" for live transactions
POLAR_SERVER=sandbox

# --- Inngest (Background Jobs) ------------------------------------------------
# Inngest is auto-detected locally but needs keys for production
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key
